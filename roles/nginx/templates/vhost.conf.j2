server {
    listen 80;
    listen [::]:80;
    
    server_name {{ item }} www.{{ item }};
    
    root /var/www/{{ item }};
    index index.html index.htm;
    
    access_log /var/log/nginx/{{ item }}_access.log;
    error_log /var/log/nginx/{{ item }}_error.log;
    
    location / {
        try_files $uri $uri/ =404;
    }
}
